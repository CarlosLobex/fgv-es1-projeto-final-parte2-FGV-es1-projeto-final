classDiagram
    class Usuario {
        +int id
        +string nome
        +string email
        +string senha_hash
        +datetime criado_em
    }

    class Pergunta {
        +int id
        +string titulo
        +string corpo
        +int autor_id
        +datetime criado_em
        +int votos_total
    }

    class Resposta {
        +int id
        +string corpo
        +int pergunta_id
        +int autor_id
        +datetime criado_em
    }

    class Tag {
        +int id
        +string nome
        +string slug
    }

    class PerguntaTag {
        +int pergunta_id
        +int tag_id
    }

    class Voto {
        +int id
        +int usuario_id
        +int pergunta_id
        +string tipo
        +datetime criado_em
    }

    Usuario "1" --> "0..*" Pergunta : cria
    Usuario "1" --> "0..*" Resposta : responde
    Usuario "1" --> "0..*" Voto : registra

    Pergunta "1" --> "0..*" Resposta : possui
    Pergunta "1" --> "0..*" Voto : recebe
    Pergunta "0..*" --> "0..3" Tag : categorizada por
    PerguntaTag ..> Pergunta : referencia
    PerguntaTag ..> Tag : referencia
