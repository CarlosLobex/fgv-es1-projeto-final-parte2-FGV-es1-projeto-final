sequenceDiagram
    actor Usuario
    participant Frontend
    participant API as API (Express)
    participant Banco as Banco (SQLite)

    Usuario->>Frontend: digita palavra-chave no campo de busca
    Frontend->>API: GET /perguntas?q=palavra-chave

    API->>Banco: SELECT * FROM perguntas WHERE titulo LIKE '%palavra%' OR corpo LIKE '%palavra%'

    alt Resultados encontrados
        Banco-->>API: retorna lista de perguntas
        API-->>Frontend: 200 OK — JSON com perguntas
        Frontend-->>Usuario: exibe lista filtrada de perguntas
    else Nenhum resultado
        Banco-->>API: retorna lista vazia []
        API-->>Frontend: 200 OK — JSON []
        Frontend-->>Usuario: exibe mensagem "Nenhuma pergunta encontrada"
    else Erro no servidor
        Banco-->>API: erro de execução
        API-->>Frontend: 500 Internal Server Error
        Frontend-->>Usuario: exibe mensagem "Erro ao realizar a busca"
    end
